# Runtime mode used by the backend service.
APP_ENV=development

# Logging verbosity for the FastAPI application.
LOG_LEVEL=INFO

# Public container-facing ports.
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379

# PostgreSQL configuration for the TimescaleDB service.
POSTGRES_DB=neurocity
POSTGRES_USER=neurocity_admin
POSTGRES_PASSWORD=NeuroCityPg_2026!
POSTGRES_HOST=postgres

# Backend database connection string.
DATABASE_URL=postgresql://neurocity_admin:NeuroCityPg_2026!@postgres:5432/neurocity

# Redis connection details for cache and messaging layers.
REDIS_HOST=redis
REDIS_URL=redis://redis:6379/0

# JWT settings for API authentication.
JWT_SECRET=neurocity-dev-jwt-secret-2026-alpha-grid
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Browser origins allowed to call the backend.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend-to-backend base URL exposed to the browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
